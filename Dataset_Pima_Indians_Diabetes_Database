      "source": [
        "import pandas as pd\n",
        "import matplotlib.pyplot as plt\n",
        "import seaborn as sns\n",
        "\n",
        "#โหลดไฟล์ diabetes.csv เข้าไปใน DataFrame ของ pandas\n",
        "df_diabetes = pd.read_csv('/content/diabetes.csv')\n",
        "\n",
        "# เลือกเฉพาะคอลัมน์ที่เป็นตัวเลข โดยไม่รวมคอลัมน์ 'Outcome' เพื่อใช้วิเคราะห์แต่ละตัวแปรแยกกัน\n",
        "numerical_features = [col for col in df_diabetes.select_dtypes(include=['number']).columns if col != 'Outcome']\n",
        "\n",
        "# คำนวณจำนวนแถวและจำนวนคอลัมน์สำหรับตาราง subplot\n",
        "num_features = len(numerical_features)\n",
        "n_cols = 3 # For example, 3 columns per row\n",
        "n_rows = (num_features + n_cols - 1) // n_cols # Calculate rows needed\n",
        "\n",
        "# ตั้งค่ารูปภาพ (figure) และแกนกราฟ (axes) ใน matplotlib\n",
        "fig, axes = plt.subplots(nrows=n_rows, ncols=n_cols, figsize=(5 * n_cols, 4 * n_rows))\n",
        "axes = axes.flatten() # Flatten the 2D array of axes for easy iteration\n",
        "\n",
        "# วนลูปผ่านคอลัมน์ที่เป็นตัวเลข และสร้างกราฟ boxplot สำหรับแต่ละคอลัมน์\n",
        "for i, col in enumerate(numerical_features):\n",
        "    if i < len(axes): # Ensure we don't try to plot beyond available axes\n",
        "        sns.boxplot(x='Outcome', y=col, data=df_diabetes, ax=axes[i], palette='viridis', hue='Outcome', legend=False)\n",
        "        axes[i].set_title(f'Distribution of {col} by Outcome')\n",
        "        axes[i].set_xlabel('Outcome (0=Non-Diabetic, 1=Diabetic)')\n",
        "        axes[i].set_ylabel(col)\n",
        "\n",
        "# ซ่อน subplot ที่ไม่ได้ใช้งาน\n",
        "for j in range(i + 1, len(axes)):\n",
        "    fig.delaxes(axes[j])\n",
        "\n",
        "plt.tight_layout() # ปรับการจัดวางเลย์เอาต์เพื่อป้องกันไม่ให้ชื่อกราฟหรือป้ายกำกับซ้อนทับกัน\n",
        "plt.show()"
      ]
    },
